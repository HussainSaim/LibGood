<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/log_reading_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/select_book_label"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/bookSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/emptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_books_message"
        android:textColor="@color/textSecondary"
        android:visibility="gone"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pages_read_label"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/pagesField"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/pages_read_hint"
        android:inputType="number"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/submitButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/log_session"
        android:padding="16dp"
        android:textSize="18sp"
        android:backgroundTint="@color/primary"
        android:textColor="@android:color/white"/>

</LinearLayout>
